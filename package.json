{
  "name": "shapewebs-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@shapewebs/web",
    "dev:admin": "turbo run dev --filter=@shapewebs/admin",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf .turbo",
    "supabase:status": "pnpm dlx supabase@2.88.1 status",
    "supabase:start": "pnpm dlx supabase@2.88.1 start",
    "supabase:reset": "pnpm dlx supabase@2.88.1 db reset",
    "supabase:stop": "pnpm dlx supabase@2.88.1 stop"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "turbo": "^2.5.2",
    "typescript": "^5",
    "zod": "^4.1.5"
  }
}
